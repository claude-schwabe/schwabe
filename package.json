{
  "name": "schwabe",
  "version": "1.0.2",
  "description": "Your token limit just reset and you've got 37% to burn before it expires. Use every last one — gloriously.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claude-schwabe/schwabe.git"
  },
